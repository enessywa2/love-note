generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  events    Event[]
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  title     String
  month     Int
  day       Int
  emoji     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
