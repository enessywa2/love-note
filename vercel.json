{
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/icons/(.*)",
      "destination": "/icons/$1"
    },
    {
      "source": "/(.*\\.(?:css|js|png|jpg|jpeg|svg|webp|ico|json|txt|webmanifest|map))",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/push",
      "schedule": "0 12 * * *"
    }
  ]
}
